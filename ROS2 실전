# 부록: 주요 명령 및 팁
source /opt/ros/<버전>/setup.bash = ROS 2 환경 활성화
.bashrc, alias_setting.sh         = 배시 환경 설정 파일 및 alias 관리
export ROS_DOMAIN_ID=<숫자>       = ROS 도메인 아이디 설정
ros2 run demo_nodes_cpp talker    = 설치 확인용 간단한 ROS 2 노드 실행
ros2 topic list                   = 현재 활성화된 ROS 2 토픽 목록 조회
ros2 topic echo <토픽명>          = 특정 토픽 메시지 실시간 출력
rqt_image_view                    = ROS 이미지 토픽 시각화 도구
rqt                               = ROS 시각화 툴 (플러그인 설치 필요)
ros2 launch <패키지> <런치파일>    = ROS 2 런치 파일 실행
git clone <주소>                  = Git 저장소 복제
colcon build                     = ROS 2 워크스페이스 빌드
